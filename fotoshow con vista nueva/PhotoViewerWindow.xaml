<Window x:Class="Fotoshow.PhotoViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Visor de Fotos"
        WindowState="Maximized"
        WindowStyle="None"
        Background="Black"
        KeyDown="Window_KeyDown"
        Loaded="Window_Loaded">

    <Window.Resources>
        <!-- Estilo para botones overlay -->
        <Style x:Key="OverlayButton" TargetType="Button">
            <Setter Property="Background" Value="#60000000"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="30">
                            <ContentPresenter HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#80FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid MouseWheel="Window_MouseWheel"
          MouseLeftButtonDown="Image_MouseLeftButtonDown"
          MouseLeftButtonUp="Image_MouseLeftButtonUp"
          MouseMove="Image_MouseMove">
        <!-- Imagen principal con zoom -->
        <Image x:Name="MainImage"
               Stretch="Uniform"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               RenderTransformOrigin="0,0">
            <Image.RenderTransform>
                <TransformGroup>
                    <ScaleTransform x:Name="ImageScale" ScaleX="1" ScaleY="1"/>
                    <TranslateTransform x:Name="ImageTranslate" X="0" Y="0"/>
                </TransformGroup>
            </Image.RenderTransform>
        </Image>

        <!-- Controles overlay (se muestran al pasar el mouse) -->
        <Grid x:Name="ControlsOverlay" Background="Transparent" Opacity="0" IsHitTestVisible="True">

            <!-- Botón cerrar (arriba derecha) -->
            <Button HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="20"
                    Width="50" Height="50"
                    Click="Close_Click"
                    Style="{StaticResource OverlayButton}">
                <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="White"/>
            </Button>

            <!-- Controles inferiores -->
            <Border VerticalAlignment="Bottom" HorizontalAlignment="Center"
                    Background="#60000000" CornerRadius="8" Padding="8,4" Margin="0,0,0,24">
            <StackPanel Orientation="Horizontal">

                <!-- Anterior -->
                <Button Width="60" Height="60"
                        Margin="10"
                        Click="Previous_Click"
                        Style="{StaticResource OverlayButton}">
                    <TextBlock Text="&#xE76B;" FontFamily="Segoe MDL2 Assets" FontSize="24" Foreground="White"/>
                </Button>

                <!-- Play/Pause carrusel -->
                <Button x:Name="PlayPauseButton"
                        Width="60" Height="60"
                        Margin="10"
                        Click="PlayPause_Click"
                        Style="{StaticResource OverlayButton}">
                    <TextBlock x:Name="PlayPauseIcon" Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="24" Foreground="White"/>
                </Button>

                <!-- Siguiente -->
                <Button Width="60" Height="60"
                        Margin="10"
                        Click="Next_Click"
                        Style="{StaticResource OverlayButton}">
                    <TextBlock Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="24" Foreground="White"/>
                </Button>
            </StackPanel>
            </Border>

            <!-- Info foto (abajo izquierda) -->
            <Border VerticalAlignment="Bottom" HorizontalAlignment="Left"
                    Background="#60000000" CornerRadius="6" Padding="10,6" Margin="20,0,0,24">
            <StackPanel>
                <TextBlock x:Name="PhotoNameText"
                           Text=""
                           FontFamily="Segoe UI"
                           FontSize="16"
                           Foreground="White"
                           Margin="0,0,0,5"/>
                <TextBlock x:Name="PhotoIndexText"
                           Text=""
                           FontFamily="Segoe UI"
                           FontSize="14"
                           Foreground="#CCCCCC"/>
            </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
