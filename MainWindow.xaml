<Window x:Class="Fotoshow.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="FOTOSHOW" 
        Height="700" Width="1200"
        MinHeight="600" MinWidth="1000"
        Background="#111111"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Estilo para ScrollBar minimalista -->
        <Style x:Key="ModernScrollBar" TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Track Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ModernThumb}"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernThumb" TargetType="Thumb">
            <Setter Property="Background" Value="#484848"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="3"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#aaaaaa"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Estilo para PhotoCard -->
        <DataTemplate x:Key="PhotoCardTemplate">
            <Border Background="#1e1e1e" 
                    BorderBrush="#333333" 
                    BorderThickness="1"
                    CornerRadius="12" 
                    Margin="6"
                    Width="220" 
                    Height="250"
                    Cursor="Hand">
                <Border.Effect>
                    <DropShadowEffect Color="Black" 
                                      Opacity="0.3" 
                                      BlurRadius="10"
                                      ShadowDepth="2"/>
                </Border.Effect>
                
                <Grid>
                    <!-- Imagen -->
                    <Image Source="{Binding ThumbnailPath}" 
                           Stretch="UniformToFill"
                           Width="200" 
                           Height="200"
                           Margin="10,10,10,0"
                           VerticalAlignment="Top">
                        <Image.Clip>
                            <RectangleGeometry Rect="0,0,200,200" RadiusX="8" RadiusY="8"/>
                        </Image.Clip>
                    </Image>

                    <!-- Info bar inferior -->
                    <StackPanel VerticalAlignment="Bottom" 
                                Margin="10,0,10,10" 
                                Height="30">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Faces detectadas -->
                            <TextBlock Grid.Column="0"
                                       Text="{Binding FacesDetected, StringFormat='👤 {0}'}"
                                       Foreground="#999999" 
                                       FontSize="11"
                                       VerticalAlignment="Center"/>

                            <!-- Cloud synced indicator -->
                            <TextBlock Grid.Column="1"
                                       Text="☁" 
                                       Foreground="#30d158" 
                                       FontSize="12"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding CloudSynced, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="54"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="26"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" 
                Background="#1a1a1a" 
                BorderBrush="#333333" 
                BorderThickness="0,0,0,1">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo -->
                <TextBlock Grid.Column="0"
                           Text="FOTO·SHOW" 
                           FontFamily="Consolas" 
                           FontSize="15"
                           FontWeight="Bold" 
                           Foreground="White" 
                           VerticalAlignment="Center"/>

                <!-- Botones centrales -->
                <StackPanel Grid.Column="1" 
                            Orientation="Horizontal" 
                            HorizontalAlignment="Left"
                            Margin="40,0,0,0">
                    <Button Content="⬜  GALERÍA" 
                            Style="{StaticResource HeaderButton}"
                            Click="Gallery_Click"/>
                    <Button Content="◎  BUSCAR" 
                            Style="{StaticResource HeaderButton}"
                            Click="Search_Click"/>
                </StackPanel>

                <!-- Botones de acción -->
                <StackPanel Grid.Column="2" 
                            Orientation="Horizontal">
                    <Button Content="📁  Abrir Carpeta" 
                            Style="{StaticResource SecondaryButton}"
                            Margin="0,0,6,0"
                            Click="OpenFolder_Click"
                            ToolTip="Abrir carpeta donde están las fotos"/>
                    <Button Content="☁  Subir a nube" 
                            Style="{StaticResource SecondaryButton}"
                            Margin="0,0,6,0"
                            Click="CloudSync_Click"/>
                    <Button Content="＋  SUBIR FOTOS" 
                            Style="{StaticResource PrimaryButton}"
                            Click="UploadPhotos_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- BODY -->
        <Grid Grid.Row="1" Background="#111111">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="180" MaxWidth="260"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT PANEL - Folders -->
            <Border Grid.Column="0" 
                    Background="#1a1a1a" 
                    BorderBrush="#333333" 
                    BorderThickness="0,0,1,0">
                <Grid Margin="12,16,12,12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header carpetas -->
                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <TextBlock Text="CARPETAS" 
                                   Foreground="#555555" 
                                   FontSize="10"
                                   FontWeight="Bold" 
                                   VerticalAlignment="Center"/>
                        <Button Content="+" 
                                Width="28" 
                                Height="28"
                                HorizontalAlignment="Right"
                                Style="{StaticResource IconButton}"
                                Click="CreateFolder_Click"/>
                    </Grid>

                    <!-- TreeView de carpetas -->
                    <TreeView Grid.Row="1" 
                              x:Name="FolderTree"
                              Background="Transparent" 
                              BorderThickness="0"
                              Foreground="#999999">
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="Padding" Value="5,4"/>
                                <Setter Property="FontSize" Value="13"/>
                            </Style>
                        </TreeView.ItemContainerStyle>
                    </TreeView>

                        <!-- Estado IA -->
                        <Border Grid.Row="2" Background="#1a1a1a" CornerRadius="6"
                                Margin="8,8,8,0" Padding="8,6">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse x:Name="AiStatusDot" Width="8" Height="8"
                                         Fill="#555" VerticalAlignment="Center"/>
                                <TextBlock x:Name="AiStatusText" Text="IA iniciando..."
                                           Foreground="#777" FontSize="10"
                                           Margin="6,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Panel personas -->
                        <Border x:Name="PersonPanel" Grid.Row="3"
                                Visibility="Collapsed" Margin="8,8,8,0">
                            <StackPanel>
                                <TextBlock Text="PERSONAS DETECTADAS"
                                           Foreground="#555" FontSize="9" FontWeight="Bold"
                                           Margin="4,0,0,4"/>
                                <ListBox x:Name="PersonList" Background="Transparent"
                                         BorderThickness="0" MaxHeight="180"
                                         Foreground="White" FontSize="11">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Padding" Value="6,3"/>
                                            <Setter Property="Cursor" Value="Hand"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                </ListBox>
                            </StackPanel>
                        </Border>
                </Grid>
            </Border>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" 
                          Width="1" 
                          Background="#333333"
                          HorizontalAlignment="Center"/>

            <!-- RIGHT PANEL - Gallery con virtualización -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Filter bar -->
                <Border Grid.Row="0" 
                        Background="#1a1a1a" 
                        BorderBrush="#333333" 
                        BorderThickness="0,0,0,1"
                        Padding="16,8">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="VISTA:" 
                                   Foreground="#555555" 
                                   FontSize="10"
                                   FontWeight="Bold" 
                                   VerticalAlignment="Center"
                                   Margin="0,0,12,0"/>
                        
                        <ComboBox x:Name="ViewModeCombo"
                                  Width="120"
                                  SelectionChanged="ViewMode_Changed">
                            <ComboBoxItem Content="Grilla" IsSelected="True"/>
                            <ComboBoxItem Content="Lista"/>
                        </ComboBox>

                        <ComboBox x:Name="ThumbnailSizeCombo"
                                  Width="120"
                                  Margin="8,0,0,0"
                                  SelectionChanged="ThumbnailSize_Changed">
                            <ComboBoxItem Content="Pequeño"/>
                            <ComboBoxItem Content="Mediano" IsSelected="True"/>
                            <ComboBoxItem Content="Grande"/>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <!-- GALERÍA VIRTUALIZADA (CRÍTICO PARA PERFORMANCE) -->
                <ListView Grid.Row="1" 
                          x:Name="PhotoGallery"
                          Background="#111111"
                          BorderThickness="0"
                          ItemTemplate="{StaticResource PhotoCardTemplate}"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          ScrollViewer.CanContentScroll="True"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling"
                          VirtualizingPanel.CacheLength="20,20"
                          VirtualizingPanel.CacheLengthUnit="Item"
                          VirtualizingPanel.ScrollUnit="Pixel"
                          Padding="10"
                          SelectionMode="Extended"
                          MouseDoubleClick="PhotoGallery_DoubleClick">
                    <ListView.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="🖨  Imprimir" Click="PrintPhoto_Click"/>
                            <MenuItem Header="👁  Ver" Click="ViewPhoto_Click"/>
                            <Separator/>
                            <MenuItem Header="🗑  Eliminar" Click="DeletePhoto_Click"/>
                        </ContextMenu>
                    </ListView.ContextMenu>
                    <ListView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ListView.ItemsPanel>
                </ListView>

                <!-- Loading indicator -->
                <Grid Grid.Row="1" 
                      x:Name="LoadingOverlay"
                      Background="#AA000000"
                      Visibility="Collapsed">
                    <StackPanel VerticalAlignment="Center" 
                                HorizontalAlignment="Center">
                        <TextBlock Text="⟳" 
                                   FontSize="48" 
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   RenderTransformOrigin="0.5,0.5">
                            <TextBlock.RenderTransform>
                                <RotateTransform x:Name="LoadingRotation"/>
                            </TextBlock.RenderTransform>
                        </TextBlock>
                        <TextBlock Text="Cargando fotos..." 
                                   Foreground="White" 
                                   FontSize="14"
                                   Margin="0,16,0,0"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>


        <!-- AI PROGRESS + LOG PANEL -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Barra de progreso IA -->
            <Border x:Name="AiProgressPanel" Grid.Row="0"
                    Background="#1a2a1a" Visibility="Collapsed"
                    BorderBrush="#333" BorderThickness="0,1,0,0">
                <Grid Margin="16,4">
                    <ProgressBar x:Name="AiProgressBar"
                                 Height="4" Value="0" Maximum="100"
                                 Background="#222" Foreground="#34D399"
                                 HorizontalAlignment="Stretch"/>
                </Grid>
            </Border>

            <!-- Panel de log colapsable -->
            <Border x:Name="LogPanel" Grid.Row="1"
                    Background="#0d0d0d" Height="0"
                    BorderBrush="#2a2a2a" BorderThickness="0,1,0,0"
                    ClipToBounds="True">
                <ListBox x:Name="LogList"
                         Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         Margin="12,6">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}"
                                       Foreground="#3ddc84"
                                       FontFamily="Consolas" FontSize="11"
                                       TextWrapping="NoWrap"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Padding" Value="0,1"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </Border>
        </Grid>

                <!-- STATUS BAR -->
        <Border Grid.Row="3" 
                Background="#1a1a1a" 
                BorderBrush="#333333" 
                BorderThickness="0,1,0,0">
            <Grid Margin="16,0">
                <TextBlock x:Name="StatusText" 
                           Text="Listo" 
                           Foreground="#999999" 
                           FontFamily="Consolas" 
                           FontSize="11"
                           VerticalAlignment="Center"/>
                
                <StackPanel Orientation="Horizontal" 
                            HorizontalAlignment="Right">
                    <!-- Filtro activo badge -->
                    <Border x:Name="PersonFilterPanel"
                            Visibility="Collapsed"
                            Background="#1e3a2a"
                            BorderBrush="#34D399"
                            BorderThickness="1"
                            CornerRadius="4"
                            Margin="0,0,8,0"
                            Padding="8,2">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="PersonFilterBadge"
                                       Text=""
                                       Foreground="#34D399"
                                       FontSize="11"
                                       VerticalAlignment="Center"/>
                            <Button Content="✕"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Foreground="#34D399"
                                    FontSize="10"
                                    Margin="6,0,0,0"
                                    Cursor="Hand"
                                    Click="ClearPersonFilter_Click"/>
                        </StackPanel>
                    </Border>

                    <TextBlock x:Name="PhotoCountText" 
                               Text="0 fotos" 
                               Foreground="#999999" 
                               FontSize="11"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0"/>
                    <Button Content="▲ LOG" 
                            Style="{StaticResource StatusButton}"
                            Click="ToggleLog_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
