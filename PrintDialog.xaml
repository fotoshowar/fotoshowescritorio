<Window x:Class="Fotoshow.PrintDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🖨  Imprimir Foto" 
        Height="720" Width="1000"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterOwner"
        Background="#111111">
    
    <Window.Resources>
        <!-- Estilo para Sliders -->
        <Style x:Key="PrintSlider" TargetType="Slider">
            <Setter Property="Minimum" Value="-100"/>
            <Setter Property="Maximum" Value="100"/>
            <Setter Property="Value" Value="0"/>
            <Setter Property="TickFrequency" Value="1"/>
            <Setter Property="IsSnapToTickEnabled" Value="True"/>
        </Style>

        <!-- Estilo para Labels de valores -->
        <Style x:Key="ValueLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="MinWidth" Value="40"/>
            <Setter Property="TextAlignment" Value="Right"/>
        </Style>

        <!-- Estilo para botones de marco -->
        <Style x:Key="FrameButton" TargetType="Border">
            <Setter Property="Width" Value="90"/>
            <Setter Property="Height" Value="100"/>
            <Setter Property="Background" Value="#222222"/>
            <Setter Property="BorderBrush" Value="#333333"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="4"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="#1a1a1a" BorderBrush="#333333" BorderThickness="0,0,0,1" Padding="20,14">
            <Grid>
                <TextBlock Text="🖨  IMPRIMIR FOTO" FontSize="14" FontWeight="Bold" Foreground="White"/>
                <TextBlock x:Name="OrientationText" Text="Portrait" HorizontalAlignment="Right" 
                           Foreground="#999999" FontSize="12"/>
            </Grid>
        </Border>

        <!-- BODY -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT PANEL - Controles -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="20">
                    
                    <!-- MARCO -->
                    <TextBlock Text="MARCO" Foreground="#666666" FontSize="10" FontWeight="Bold" 
                               Margin="0,0,0,8"/>
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Height="120">
                        <StackPanel x:Name="FramesPanel" Orientation="Horizontal"/>
                    </ScrollViewer>

                    <!-- TAMAÑO EN EL MARCO -->
                    <TextBlock Text="TAMAÑO EN EL MARCO" Foreground="#666666" FontSize="10" FontWeight="Bold" 
                               Margin="0,16,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <Slider x:Name="ScaleSlider" Minimum="70" Maximum="100" Value="95" 
                                ValueChanged="ScaleSlider_ValueChanged"/>
                        <TextBlock Grid.Column="1" x:Name="ScaleValue" Text="95%" Style="{StaticResource ValueLabel}"/>
                    </Grid>

                    <!-- MARGEN DEL PAPEL -->
                    <TextBlock Text="MARGEN DEL PAPEL" Foreground="#666666" FontSize="10" FontWeight="Bold" 
                               Margin="0,16,0,8"/>
                    <ComboBox x:Name="MarginCombo" SelectionChanged="MarginCombo_SelectionChanged">
                        <ComboBoxItem Content="Sin margen (0mm)" Tag="0"/>
                        <ComboBoxItem Content="Mínimo (3mm)" Tag="35"/>
                        <ComboBoxItem Content="Pequeño (5mm)" Tag="59"/>
                        <ComboBoxItem Content="Normal (8mm) ✓" Tag="95" IsSelected="True"/>
                        <ComboBoxItem Content="Estándar (10mm)" Tag="118"/>
                        <ComboBoxItem Content="Amplio (15mm)" Tag="177"/>
                    </ComboBox>

                    <Separator Margin="0,20" Background="#333333"/>

                    <!-- AJUSTES DE IMAGEN -->
                    <TextBlock Text="AJUSTES DE IMAGEN" Foreground="#666666" FontSize="10" FontWeight="Bold" 
                               Margin="0,0,0,12"/>

                    <!-- Brillo -->
                    <TextBlock Text="Brillo:" Foreground="#999999" FontSize="11" Margin="0,0,0,4"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <Slider x:Name="BrightnessSlider" Style="{StaticResource PrintSlider}" 
                                ValueChanged="Adjustment_ValueChanged"/>
                        <TextBlock Grid.Column="1" x:Name="BrightnessValue" Text="0" Style="{StaticResource ValueLabel}"/>
                    </Grid>

                    <!-- Contraste -->
                    <TextBlock Text="Contraste:" Foreground="#999999" FontSize="11" Margin="0,0,0,4"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <Slider x:Name="ContrastSlider" Style="{StaticResource PrintSlider}" 
                                ValueChanged="Adjustment_ValueChanged"/>
                        <TextBlock Grid.Column="1" x:Name="ContrastValue" Text="0" Style="{StaticResource ValueLabel}"/>
                    </Grid>

                    <!-- Gamma -->
                    <TextBlock Text="Gamma:" Foreground="#999999" FontSize="11" Margin="0,0,0,4"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <Slider x:Name="GammaSlider" Minimum="50" Maximum="200" Value="100" 
                                ValueChanged="Adjustment_ValueChanged"/>
                        <TextBlock Grid.Column="1" x:Name="GammaValue" Text="1.0" Style="{StaticResource ValueLabel}"/>
                    </Grid>

                    <!-- Saturación -->
                    <TextBlock Text="Saturación:" Foreground="#999999" FontSize="11" Margin="0,0,0,4"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <Slider x:Name="SaturationSlider" Style="{StaticResource PrintSlider}" 
                                ValueChanged="Adjustment_ValueChanged"/>
                        <TextBlock Grid.Column="1" x:Name="SaturationValue" Text="0" Style="{StaticResource ValueLabel}"/>
                    </Grid>

                    <!-- Nitidez -->
                    <TextBlock Text="Nitidez:" Foreground="#999999" FontSize="11" Margin="0,0,0,4"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <Slider x:Name="SharpnessSlider" Minimum="0" Maximum="100" Value="0" 
                                ValueChanged="Adjustment_ValueChanged"/>
                        <TextBlock Grid.Column="1" x:Name="SharpnessValue" Text="0" Style="{StaticResource ValueLabel}"/>
                    </Grid>

                    <!-- Temperatura -->
                    <TextBlock Text="Temperatura:" Foreground="#999999" FontSize="11" Margin="0,0,0,4"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <Slider x:Name="TemperatureSlider" Style="{StaticResource PrintSlider}" 
                                ValueChanged="Adjustment_ValueChanged"/>
                        <TextBlock Grid.Column="1" x:Name="TemperatureValue" Text="0" Style="{StaticResource ValueLabel}"/>
                    </Grid>

                    <!-- Botón Reset -->
                    <Button Content="↺  Resetear ajustes" Click="ResetAdjustments_Click"
                            Padding="8,5" Margin="0,8,0,0" HorizontalAlignment="Left"/>
                </StackPanel>
            </ScrollViewer>

            <!-- RIGHT PANEL - Preview -->
            <Border Grid.Column="1" Background="#1a1a1a" BorderBrush="#333333" BorderThickness="1,0,0,0" Padding="16">
                <StackPanel>
                    <TextBlock Text="VISTA PREVIA  A5" FontSize="9" FontWeight="Bold" Foreground="#666666" 
                               TextAlignment="Center" Margin="0,0,0,6"/>
                    
                    <Border x:Name="PreviewBorder" Background="White" BorderBrush="#444444" BorderThickness="1"
                            Width="280" Height="396" HorizontalAlignment="Center">
                        <Image x:Name="PreviewImage" Stretch="Uniform"/>
                    </Border>

                    <TextBlock Text="Cargando preview..." x:Name="PreviewStatus" 
                               Foreground="#666666" FontSize="10" TextAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- FOOTER -->
        <Border Grid.Row="2" Background="#1a1a1a" BorderBrush="#333333" BorderThickness="0,1,0,0" Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="Impresora:" Foreground="#999999" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox x:Name="PrinterCombo" Width="200"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="Cancelar" Click="Cancel_Click" Padding="10,8" Margin="0,0,8,0" MinWidth="100"/>
                    <Button x:Name="PrintButton" Content="🖨  IMPRIMIR" Click="Print_Click" 
                            Padding="12,8" MinWidth="140" 
                            Background="White" Foreground="Black" FontWeight="Bold"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Loading Overlay -->
        <Grid x:Name="LoadingOverlay" Grid.RowSpan="3" Background="#CC000000" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="⏳" FontSize="48" HorizontalAlignment="Center"/>
                <TextBlock Text="Generando preview..." Foreground="White" FontSize="14" Margin="0,16,0,0"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
